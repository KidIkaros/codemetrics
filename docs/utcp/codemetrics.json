{
  "info": {
    "name": "codemetrics",
    "version": "1.0.0",
    "description": "AI-native code quality audit toolkit - 10 tools for automated code analysis. Designed for CI/CD pipelines and AI agents.",
    "documentation": "https://github.com/KidIkaros/codemetrics",
    "license": "Apache-2.0 OR OPL-1.1",
    "tags": ["code-quality", "static-analysis", "rust", "metrics", "security"]
  },
  "parameters": {
    "path": {
      "type": "string",
      "description": "Path to analyze (file or directory)",
      "required": true
    },
    "recursive": {
      "type": "boolean",
      "description": "Recursively scan directories",
      "default": false
    },
    "format": {
      "type": "string",
      "enum": ["text", "json", "ndjson", "sarif"],
      "default": "text",
      "description": "Output format"
    },
    "minScore": {
      "type": "number",
      "description": "Minimum score threshold for filtering results"
    }
  },
  "tools": [
    {
      "name": "crap",
      "description": "Calculate CRAP (Change Risk Anti-Patterns) risk scores for functions. CRAP = comp² × (1 - coverage/100)³ + comp. Scores above 30 indicate high-risk code needing tests.",
      "tags": ["metrics", "risk", "maintenance", "complexity", "testing"],
      "average_response_size": 1024,
      "call": {
        "syntax": "codemetrics crap {path} --recursive --format {format} --min-score {minScore}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "recursive": {"type": "boolean", "default": true},
        "format": {"type": "string", "default": "json"},
        "minScore": {"type": "number", "default": 15},
        "coverage": {"type": "string", "description": "Path to coverage file (lcov format)"},
        "coveragePct": {"type": "number", "description": "Override coverage percentage"}
      },
      "outputs": {
        "type": "array",
        "items": {
          "properties": {
            "function": {"type": "string"},
            "file": {"type": "string"},
            "line": {"type": "number"},
            "complexity": {"type": "number"},
            "crap": {"type": "number"},
            "category": {"type": "string"}
          }
        }
      },
      "error_handling": {
        "exit_codes": {
          "0": "Success - analysis complete",
          "1": "Error - check stderr for details"
        }
      }
    },
    {
      "name": "mutate",
      "description": "Mutation testing to evaluate test suite quality. Introduces deliberate code changes (mutants) and checks if tests detect them. Low mutation score = weak tests.",
      "tags": ["testing", "mutation", "test-quality"],
      "average_response_size": 2048,
      "call": {
        "syntax": "codemetrics mutate {path} -p {package} --max-mutants {maxMutants} --timeout {timeout} --format {format}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "description": "Path to Rust crate", "required": true},
        "package": {"type": "string", "description": "Package name to test (auto-detected if not specified)", "required": false},
        "maxMutants": {"type": "number", "default": 5, "max": 50},
        "timeout": {"type": "number", "default": 30, "description": "Seconds per test run"},
        "files": {"type": "string", "description": "Comma-separated file filter"},
        "strategy": {"type": "string", "enum": ["all", "standard", "bitwise", "arithmetic"], "default": "all"}
      },
      "outputs": {
        "type": "object",
        "properties": {
          "total_mutants": {"type": "number"},
          "killed": {"type": "number"},
          "survived": {"type": "number"},
          "mutation_score": {"type": "number"},
          "results": {
            "type": "array",
            "items": {
              "properties": {
                "id": {"type": "number"},
                "file": {"type": "string"},
                "line": {"type": "number"},
                "status": {"type": "string", "enum": ["killed", "survived", "timeout", "error"]}
              }
            }
          }
        }
      },
      "error_handling": {
        "exit_codes": {
          "0": "Success - all tests catch mutants",
          "1": "Tests fail on original code or mutants survive"
        }
      },
      "notes": "Requires cargo test to pass on original code first. Won't work on crates with failing tests."
    },
    {
      "name": "debt",
      "description": "Scan for technical debt markers: TODO, FIXME, HACK, XXX. Shows who created them (via git blame) and urgency.",
      "tags": ["technical-debt", "todos", "cleanup"],
      "average_response_size": 512,
      "call": {
        "syntax": "codemetrics debt {path} --recursive --format {format} --marker {marker}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "recursive": {"type": "boolean", "default": true},
        "marker": {"type": "string", "default": "TODO,FIXME,HACK,XXX", "description": "Comma-separated markers to find"},
        "sort": {"type": "string", "enum": ["file", "author", "date"], "default": "file"}
      },
      "outputs": {
        "type": "array",
        "items": {
          "properties": {
            "marker": {"type": "string"},
            "file": {"type": "string"},
            "line": {"type": "number"},
            "content": {"type": "string"},
            "author": {"type": "string"},
            "date": {"type": "string"}
          }
        }
      }
    },
    {
      "name": "riskmap",
      "description": "Cross-reference git churn (changes) with code complexity. Identifies files that change often AND are complex - the highest risk for bugs.",
      "tags": ["risk", "churn", "complexity", "maintenance"],
      "average_response_size": 1024,
      "call": {
        "syntax": "codemetrics riskmap {path} --min-risk {minRisk} --since {since}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "minRisk": {"type": "number", "default": 30, "description": "Minimum risk score threshold"},
        "since": {"type": "string", "default": "3 months ago", "description": "Git history timeframe"}
      },
      "outputs": {
        "type": "array",
        "items": {
          "properties": {
            "file": {"type": "string"},
            "changes": {"type": "number"},
            "complexity": {"type": "number"},
            "risk_score": {"type": "number"}
          }
        }
      }
    },
    {
      "name": "doccov",
      "description": "Calculate documentation coverage for public APIs. Shows percentage of functions/types with doc comments.",
      "tags": ["documentation", "docs", "api"],
      "average_response_size": 256,
      "call": {
        "syntax": "codemetrics doccov {path} --recursive --format {format} --min {minCoverage}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "recursive": {"type": "boolean", "default": true},
        "minCoverage": {"type": "number", "default": 80, "description": "Minimum coverage percentage"}
      },
      "outputs": {
        "type": "object",
        "properties": {
          "total_items": {"type": "number"},
          "documented": {"type": "number"},
          "coverage_percent": {"type": "number"},
          "status": {"type": "string", "enum": ["excellent", "good", "low", "critical"]}
        }
      }
    },
    {
      "name": "taint",
      "description": "Detect taint/sensitive data flow. Tracks potentially sensitive data (passwords, keys, PII) from sources to sinks.",
      "tags": ["security", "taint", "data-flow", "secrets"],
      "average_response_size": 512,
      "call": {
        "syntax": "codemetrics taint {path} --recursive --format {format} --rule {rule}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "recursive": {"type": "boolean", "default": true},
        "rule": {"type": "string", "description": "Specific taint rule to check"}
      },
      "outputs": {
        "type": "array",
        "items": {
          "properties": {
            "severity": {"type": "string", "enum": ["high", "medium", "low"]},
            "file": {"type": "string"},
            "line": {"type": "number"},
            "source": {"type": "string"},
            "sink": {"type": "string"},
            "description": {"type": "string"}
          }
        }
      }
    },
    {
      "name": "coupling",
      "description": "Analyze module dependency graphs. Shows fan-in (dependencies) and fan-out (dependents) to identify tight coupling.",
      "tags": ["coupling", "dependencies", "architecture"],
      "average_response_size": 768,
      "call": {
        "syntax": "codemetrics coupling {path} --format {format} --min-coupling {minCoupling}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "minCoupling": {"type": "number", "default": 5, "description": "Minimum coupling threshold"}
      },
      "outputs": {
        "type": "object",
        "properties": {
          "modules": {
            "type": "array",
            "items": {
              "properties": {
                "module": {"type": "string"},
                "fan_in": {"type": "number"},
                "fan_out": {"type": "number"}
              }
            }
          }
        }
      }
    },
    {
      "name": "dupfind",
      "description": "Find code duplication using AST-based structural fingerprinting. Identical code blocks across files.",
      "tags": ["duplication", "refactoring", "dry"],
      "average_response_size": 1024,
      "call": {
        "syntax": "codemetrics dupfind {path} --recursive --format {format} --min-lines {minLines}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "minLines": {"type": "number", "default": 5, "description": "Minimum duplicate lines"}
      },
      "outputs": {
        "type": "array",
        "items": {
          "properties": {
            "fingerprint": {"type": "string"},
            "locations": {
              "type": "array",
              "items": {"properties": {"file": {"type": "string"}, "line": {"type": "number"}}}
            }
          }
        }
      }
    },
    {
      "name": "fuzz",
      "description": "Identify fuzzable functions that take simple inputs (strings, numbers, arrays). Helps prioritize fuzzing targets.",
      "tags": ["fuzzing", "testing", "security"],
      "average_response_size": 512,
      "call": {
        "syntax": "codemetrics fuzz {path} --recursive --format {format} --min-score {minScore}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "minScore": {"type": "number", "default": 10, "description": "Minimum fuzzability score"},
        "top": {"type": "number", "description": "Show top N functions"}
      },
      "outputs": {
        "type": "array",
        "items": {
          "properties": {
            "function": {"type": "string"},
            "file": {"type": "string"},
            "line": {"type": "number"},
            "score": {"type": "number"},
            "params": {"type": "number"},
            "has_harness": {"type": "boolean"}
          }
        }
      }
    },
    {
      "name": "propcov",
      "description": "Detect property-based tests and unit tests. Shows test coverage strategy gaps.",
      "tags": ["testing", "property-based", "coverage"],
      "average_response_size": 256,
      "call": {
        "syntax": "codemetrics propcov {path} --recursive --format {format}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "recursive": {"type": "boolean", "default": true}
      },
      "outputs": {
        "type": "object",
        "properties": {
          "property_tests": {"type": "number"},
          "unit_tests": {"type": "number"},
          "total_functions": {"type": "number"},
          "coverage_percent": {"type": "number"},
          "status": {"type": "string", "enum": ["excellent", "good", "low", "critical"]}
        }
      }
    },
    {
      "name": "quality",
      "description": "Run all quality tools in one batch. Unified CLI that runs debt, crap, doccov, coupling, riskmap, dupfind, propcov, taint, fuzz, and mutate.",
      "tags": ["batch", "full-audit", "ci"],
      "average_response_size": 4096,
      "call": {
        "syntax": "codemetrics run {path} --format {format}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "format": {"type": "string", "default": "sarif", "enum": ["text", "json", "sarif", "ndjson"]},
        "checks": {"type": "string", "description": "Comma-separated tool list (default: all)"}
      },
      "outputs": {
        "type": "object",
        "properties": {
          "results": {"type": "array"},
          "summary": {
            "properties": {
              "total_tools": {"type": "number"},
              "passed": {"type": "number"},
              "failed": {"type": "number"}
            }
          }
        }
      },
      "notes": "Recommended for CI/CD. Outputs SARIF format compatible with GitHub Security tab."
    },
    {
      "name": "init",
      "description": "Auto-detect project ecosystem and write language-tuned .quality.toml thresholds. With --ci also writes GitHub Actions workflow, installs pre-commit hook, seeds baseline SARIF, and records history.",
      "tags": ["setup", "config", "ci", "zero-config"],
      "average_response_size": 256,
      "call": {
        "syntax": "codemetrics init [--ci] [--output {output}]",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "ci": {"type": "boolean", "default": false, "description": "Full CI bootstrap: GHA workflow + pre-commit hook + baseline SARIF + history"},
        "output": {"type": "string", "default": ".quality.toml", "description": "Output path for config file"}
      },
      "outputs": {
        "type": "object",
        "properties": {
          "ecosystem": {"type": "string", "enum": ["Rust", "JavaScript", "TypeScript", "Python", "Go", "Unknown"]},
          "config_path": {"type": "string"}
        }
      }
    },
    {
      "name": "check",
      "description": "Run all quality checks in one call. Automatically loads thresholds from .quality.toml if present. CLI flags override file values. Returns structured JSON with per-check pass/fail, score, and threshold.",
      "tags": ["gate", "ci", "agent", "json"],
      "average_response_size": 2048,
      "call": {
        "syntax": "codemetrics check {path} --format {format}",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "required": true},
        "format": {"type": "string", "default": "json", "enum": ["text", "json"]},
        "skip": {"type": "string", "description": "Comma-separated checks to skip (e.g. taint,fuzz)"},
        "coverage": {"type": "string", "description": "Path to lcov coverage file for accurate CRAP scores"},
        "max_crap": {"type": "number", "description": "Override CRAP threshold (overrides .quality.toml)"},
        "max_debt": {"type": "number", "description": "Override max debt markers"},
        "min_doc": {"type": "number", "description": "Override min documentation coverage %"}
      },
      "outputs": {
        "type": "object",
        "properties": {
          "passed": {"type": "boolean"},
          "checks": {
            "type": "array",
            "items": {
              "properties": {
                "name": {"type": "string"},
                "passed": {"type": "boolean"},
                "score": {"type": "number"},
                "threshold": {"type": "number"},
                "message": {"type": "string"}
              }
            }
          },
          "summary": {
            "properties": {
              "total": {"type": "number"},
              "passed": {"type": "number"},
              "failed": {"type": "number"}
            }
          }
        }
      },
      "error_handling": {
        "exit_codes": {
          "0": "All checks passed",
          "1": "One or more checks failed",
          "2": "Error (parse failure, missing binary)"
        }
      },
      "notes": "Auto-loads .quality.toml. Run `codemetrics init` first to generate it. Fastest agent quality gate."
    },
    {
      "name": "watch",
      "description": "Watch for file changes and re-run checks. Auto-detects project ecosystem, test runner, and coverage command. Feeds live coverage into CRAP scores.",
      "tags": ["watch", "live", "dev-loop"],
      "average_response_size": 0,
      "call": {
        "syntax": "codemetrics watch {path} [--no-tests] [--debounce-ms {debounceMs}]",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "path": {"type": "string", "default": "."},
        "no_tests": {"type": "boolean", "default": false, "description": "Skip test + coverage run; metrics-only mode"},
        "debounce_ms": {"type": "number", "default": 500, "description": "Debounce delay in ms after file change"},
        "checks": {"type": "string", "default": "debt,doc,crap", "description": "Comma-separated checks to run on change"}
      },
      "notes": "Runs continuously. Use --no-tests for a fast feedback loop without waiting for test suite."
    },
    {
      "name": "install-hooks",
      "description": "Install a CodeMetrics pre-commit git hook. Default hook runs tests, collects coverage, then runs codemetrics check. --fast skips tests for a lightweight metrics-only hook.",
      "tags": ["hooks", "git", "pre-commit", "ci"],
      "average_response_size": 128,
      "call": {
        "syntax": "codemetrics install-hooks [--fast] [{repo}]",
        "protocol": "cli",
        "cwd": "{project_root}"
      },
      "inputs": {
        "repo": {"type": "string", "default": ".", "description": "Git repo root"},
        "fast": {"type": "boolean", "default": false, "description": "Install lightweight hook that skips test execution"}
      }
    }
  ],
  "examples": [
    {
      "name": "Zero-config setup",
      "command": "codemetrics init"
    },
    {
      "name": "CI bootstrap",
      "command": "codemetrics init --ci"
    },
    {
      "name": "Quick quality gate (agent)",
      "command": "codemetrics check . --format json"
    },
    {
      "name": "Full audit",
      "command": "codemetrics run . --format sarif > results.sarif"
    },
    {
      "name": "CRAP score check",
      "command": "codemetrics crap ./src --recursive --format json"
    },
    {
      "name": "Mutation testing",
      "command": "codemetrics mutate . -p ast-parse-ts --max-mutants 5 --format json"
    },
    {
      "name": "Risk map",
      "command": "codemetrics riskmap . --format json"
    },
    {
      "name": "MCP server",
      "command": "codemetrics-server --mode stdio"
    }
  ]
}